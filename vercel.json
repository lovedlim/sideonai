{
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/typing",
      "destination": "https://claude-typing-test.vercel.app/",
      "permanent": false
    },
    {
      "source": "/md",
      "destination": "https://md-editor-pink-phi.vercel.app/",
      "permanent": false
    },
    {
      "source": "/code",
      "destination": "https://codingpang.vercel.app/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
